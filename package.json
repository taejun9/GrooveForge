{
  "name": "grooveforge",
  "version": "0.1.0",
  "private": true,
  "description": "All-genre desktop beat workstation for direct composition, sound design, mixing, mastering, and export.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build && tsc -p tsconfig.electron.json",
    "desktop": "npm run build && electron .",
    "desktop:smoke": "node harness/scripts/run_desktop_entry_smoke.mjs",
    "desktop:launch-smoke": "node harness/scripts/run_desktop_launch_smoke.mjs",
    "desktop:package-smoke": "node harness/scripts/run_desktop_package_smoke.mjs",
    "desktop:adhoc-sign-smoke": "node harness/scripts/run_desktop_adhoc_sign_smoke.mjs",
    "desktop:hardened-runtime-readiness-smoke": "node harness/scripts/run_desktop_hardened_runtime_readiness_smoke.mjs",
    "desktop:dmg-smoke": "node harness/scripts/run_desktop_dmg_smoke.mjs",
    "desktop:install-smoke": "node harness/scripts/run_desktop_install_smoke.mjs",
    "desktop:gatekeeper-readiness-smoke": "node harness/scripts/run_desktop_gatekeeper_readiness_smoke.mjs",
    "desktop:release-manifest-smoke": "node harness/scripts/run_desktop_release_manifest_smoke.mjs",
    "desktop:release-notes-smoke": "node harness/scripts/run_desktop_release_notes_smoke.mjs",
    "desktop:support-artifact-smoke": "node harness/scripts/run_desktop_support_artifact_smoke.mjs",
    "desktop:update-feed-config-smoke": "node --experimental-strip-types --import ./harness/scripts/register_ts_loader.mjs harness/scripts/run_desktop_update_feed_config_smoke.mjs",
    "desktop:update-metadata-policy-smoke": "node harness/scripts/run_desktop_update_metadata_policy_smoke.mjs",
    "desktop:update-metadata-artifacts-smoke": "node harness/scripts/run_desktop_update_metadata_artifacts_smoke.mjs",
    "desktop:auto-update-readiness-smoke": "node --experimental-strip-types --import ./harness/scripts/register_ts_loader.mjs harness/scripts/run_desktop_auto_update_readiness_smoke.mjs",
    "desktop:developer-id-readiness-smoke": "node harness/scripts/run_desktop_developer_id_readiness_smoke.mjs",
    "desktop:developer-id-signing-smoke": "node harness/scripts/run_desktop_developer_id_signing_smoke.mjs",
    "desktop:notarization-smoke": "node harness/scripts/run_desktop_notarization_smoke.mjs",
    "desktop:notarized-gatekeeper-smoke": "node harness/scripts/run_desktop_notarized_gatekeeper_smoke.mjs",
    "desktop:distribution-manual-qa-smoke": "node harness/scripts/run_desktop_distribution_manual_qa_smoke.mjs",
    "desktop:distribution-channel-qa-smoke": "node harness/scripts/run_desktop_distribution_channel_qa_smoke.mjs",
    "desktop:distribution-handoff-smoke": "node harness/scripts/run_desktop_distribution_handoff_smoke.mjs",
    "desktop:distribution-bundle-manifest-smoke": "node harness/scripts/run_desktop_distribution_bundle_manifest_smoke.mjs",
    "desktop:distribution-env-template-smoke": "node harness/scripts/run_desktop_distribution_env_template_smoke.mjs",
    "desktop:distribution-private-inputs-smoke": "node harness/scripts/run_desktop_distribution_private_inputs_smoke.mjs",
    "desktop:completion-audit-smoke": "node harness/scripts/run_desktop_completion_audit_smoke.mjs",
    "desktop:external-distribution-gate-smoke": "node harness/scripts/run_desktop_external_distribution_gate_smoke.mjs --dry-run",
    "desktop:external-remediation-smoke": "node harness/scripts/run_desktop_external_remediation_smoke.mjs",
    "desktop:completion-status-smoke": "node harness/scripts/run_desktop_completion_status_smoke.mjs",
    "desktop:external-operator-runbook-smoke": "node harness/scripts/run_desktop_external_operator_runbook_smoke.mjs",
    "desktop:external-readiness-ledger-smoke": "node harness/scripts/run_desktop_external_readiness_ledger_smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "qa": "python3 harness/scripts/run_qa.py",
    "harness:smoke": "node --experimental-strip-types --import ./harness/scripts/register_ts_loader.mjs harness/scripts/run_runtime_smoke.mjs",
    "renderer:smoke": "node harness/scripts/run_renderer_smoke.mjs",
    "workflow:smoke": "node --experimental-strip-types --import ./harness/scripts/register_ts_loader.mjs harness/scripts/run_workflow_smoke.mjs",
    "verify": "python3 harness/scripts/run_quality_gate.py && npm run renderer:smoke && npm run workflow:smoke && npm run harness:smoke && npm run typecheck && npm run build && npm run desktop:smoke && npm run desktop:launch-smoke && npm run desktop:package-smoke && npm run desktop:adhoc-sign-smoke && npm run desktop:hardened-runtime-readiness-smoke && npm run desktop:dmg-smoke && npm run desktop:install-smoke && npm run desktop:gatekeeper-readiness-smoke && npm run desktop:release-manifest-smoke && npm run desktop:release-notes-smoke && npm run desktop:support-artifact-smoke && npm run desktop:update-feed-config-smoke && npm run desktop:update-metadata-policy-smoke && npm run desktop:update-metadata-artifacts-smoke && npm run desktop:auto-update-readiness-smoke && npm run desktop:developer-id-readiness-smoke && npm run desktop:developer-id-signing-smoke && npm run desktop:notarization-smoke && npm run desktop:notarized-gatekeeper-smoke && npm run desktop:distribution-manual-qa-smoke && npm run desktop:distribution-channel-qa-smoke && npm run desktop:distribution-handoff-smoke && npm run desktop:distribution-bundle-manifest-smoke && npm run desktop:distribution-env-template-smoke && npm run desktop:distribution-private-inputs-smoke && npm run desktop:completion-audit-smoke && npm run desktop:external-distribution-gate-smoke && npm run desktop:external-remediation-smoke && npm run desktop:completion-status-smoke && npm run desktop:external-operator-runbook-smoke && npm run desktop:external-readiness-ledger-smoke",
    "release:check": "npm run qa && npm run verify",
    "release:external-check": "npm run release:check && node harness/scripts/run_desktop_external_distribution_gate_smoke.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "vite": "^8.0.16",
    "typescript": "^5.9.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "electron": "^39.2.7",
    "lucide-react": "^0.561.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
