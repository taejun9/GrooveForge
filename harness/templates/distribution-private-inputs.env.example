# GrooveForge distribution private inputs template.
# Copy this file to .env.distribution.local for local release validation.
# Never commit real values. Placeholder values are intentionally rejected.
# To use another ignored local file, export GROOVEFORGE_DISTRIBUTION_ENV_FILE with that path.

GROOVEFORGE_DISTRIBUTION_CHANNEL=<direct-download|private-beta|managed-release>
GROOVEFORGE_RELEASE_DOWNLOAD_URL=<release-download-url>
GROOVEFORGE_RELEASE_NOTES_URL=<release-notes-url>
GROOVEFORGE_SUPPORT_URL=<support-url>
GROOVEFORGE_DISTRIBUTION_QA_APPROVED=<0-or-1>

GROOVEFORGE_UPDATE_FEED_URL=<update-feed-url>
ELECTRON_UPDATE_FEED_URL=<electron-update-feed-url>
UPDATE_FEED_URL=<fallback-update-feed-url>
GROOVEFORGE_UPDATE_CHANNEL=<release-channel>
ELECTRON_UPDATE_CHANNEL=<electron-release-channel>
UPDATE_CHANNEL=<fallback-release-channel>

GROOVEFORGE_DEVELOPER_ID_IDENTITY=<developer-id-application-identity-label-or-sha1>

GROOVEFORGE_NOTARY_SUBMIT=<0-or-1>
APPLE_ID=<apple-id-email>
APPLE_TEAM_ID=<apple-team-id>
APPLE_APP_SPECIFIC_PASSWORD=<app-specific-password>
ASC_KEY_ID=<app-store-connect-key-id>
ASC_ISSUER_ID=<app-store-connect-issuer-id>
ASC_KEY_PATH=<path-to-app-store-connect-private-key>
APPLE_NOTARY_PROFILE=<notarytool-keychain-profile>
NOTARYTOOL_KEYCHAIN_PROFILE=<notarytool-keychain-profile>
